{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "timeout": 5,
            "type": "http",
            "url": "http://localhost:7849/hook/pre-read"
          }
        ],
        "matcher": "Read"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "youwhatknow init",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.rs)",
      "WebSearch",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:htmx.org)",
      "WebFetch(domain:twind.style)",
      "WebFetch(domain:rust-lang-nursery.github.io)",
      "WebFetch(domain:github.com)",
      "Bash(cargo build:*)"
    ]
  }
}
